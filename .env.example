# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Get your database URL from your PostgreSQL provider (Neon, Supabase, etc.)
# -----------------------------------------------------------------------------
DATABASE_URL='postgresql://user:password@host:port/database?sslmode=require'
# Optional: Override SSL mode (disable | require). Auto-detected based on hostname if not set.
# Useful for Docker/internal deployments where SSL is not needed.
# DATABASE_SSL_MODE=disable

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL='http://localhost:3000'
# Default billing provider (creem | stripe)
NEXT_PUBLIC_BILLING_PROVIDER="creem"

# -----------------------------------------------------------------------------
# Authentication (Better Auth)
# Generate a new secret with: openssl rand -base64 32
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET='your_better_auth_secret_here'

# Google OAuth (Get credentials from: https://console.cloud.google.com/)
GOOGLE_CLIENT_ID='your_google_client_id'
GOOGLE_CLIENT_SECRET='your_google_client_secret'

# -----------------------------------------------------------------------------
# Email (RESEND)
# Get your API key from: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY='re_your_resend_api_key'
RESEND_FROM='noreply@yourdomain.com'

# -----------------------------------------------------------------------------
# Subscriptions (Stripe) - Optional if using Creem
# -----------------------------------------------------------------------------
STRIPE_API_KEY="sk_test_your_stripe_api_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
NEXT_PUBLIC_STRIPE_STD_PRODUCT_ID="prod_xxx"
NEXT_PUBLIC_STRIPE_STD_MONTHLY_PRICE_ID="price_xxx"

NEXT_PUBLIC_STRIPE_PRO_PRODUCT_ID="prod_xxx"
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID="price_xxx"
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID="price_xxx"
NEXT_PUBLIC_STRIPE_BUSINESS_PRODUCT_ID="prod_xxx"
NEXT_PUBLIC_STRIPE_BUSINESS_MONTHLY_PRICE_ID="price_xxx"
NEXT_PUBLIC_STRIPE_BUSINESS_YEARLY_PRICE_ID="price_xxx"

# -----------------------------------------------------------------------------
# Creem (Default Billing)
# Get your API keys from: https://creem.io/dashboard
# -----------------------------------------------------------------------------
CREEM_API_KEY="creem_sk_your_api_key"
CREEM_WEBHOOK_SECRET="whsec_your_webhook_secret"

# -----------------------------------------------------------------------------
# Analytics (PostHog) - Optional
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY="your_posthog_key"
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Analytics (Plausible) - Optional
# Self-hosted or cloud Plausible analytics
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT=https://plausible.io/js/script.js

# -----------------------------------------------------------------------------
# Admin Account
# Set your email to automatically grant admin permissions
# -----------------------------------------------------------------------------
ADMIN_EMAIL="your-email@example.com"

# -----------------------------------------------------------------------------
# Debug Mode
# -----------------------------------------------------------------------------
IS_DEBUG=false

# -----------------------------------------------------------------------------
# R2/S3 Storage
# Get your credentials from Cloudflare R2 or AWS S3
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT=https://xxx.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=your_r2_access_key_id
STORAGE_SECRET_KEY=your_r2_secret_access_key
STORAGE_BUCKET=your_bucket_name
STORAGE_DOMAIN=https://pub-xxx.r2.dev

# -----------------------------------------------------------------------------
# AI Video Providers
# Get your API keys from the respective providers
# -----------------------------------------------------------------------------
# Evolink: https://evolink.ai
EVOLINK_API_KEY=sk-your_evolink_api_key

# Kie.ai: https://kie.ai
KIE_API_KEY=your_kie_api_key

# APImart: https://apimart.ai (supports Seedance 1.0/1.5, Sora 2, Wan 2.6, Veo 3.1)
APIMART_API_KEY=your_apimart_api_key

# Default provider (evolink | kie | apimart)
# The app will only use models/modes supported by this provider.
# Unsupported models are filtered from the UI and rejected by the API instead of silently falling back.
DEFAULT_AI_PROVIDER=evolink

# -----------------------------------------------------------------------------
# AI Callback (REQUIRED for production)
# Set this to your domain in production
# Local development: use localhost:3000 (callbacks won't work, polling will handle it)
# Production: use your actual domain (e.g., https://videofly.app)
# -----------------------------------------------------------------------------
AI_CALLBACK_URL=https://yourdomain.com/api/v1/video/callback
CALLBACK_HMAC_SECRET=generate_random_secret_here

# -----------------------------------------------------------------------------
# Credit & Pricing System (积分与商品配置)
# 所有商品 ID、价格、积分数量统一在 src/config/pricing-user.ts 中管理
# 无需在环境变量中配置
# -----------------------------------------------------------------------------
